rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow read: if request.auth != null && (
        request.auth.uid == userId ||
        resource.data.isPublic == true
      );
      allow create: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId;

      match /workouts/{workoutId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /nutritionDays/{dayId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /customExercises/{exerciseId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /personalRecords/{recordId} {
        allow read: if request.auth.uid == userId ||
          get(/databases/$(database)/documents/users/$(userId)).data.isPublic == true;
        allow write: if false;
      }

      match /assistantChats/{chatId} {
        allow read, write: if request.auth.uid == userId;
      }

      match /healthData/{dayId} {
        allow read, write: if request.auth.uid == userId;
      }
    }

    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Unique usernames index
    match /usernames/{username} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.userId;
      allow delete: if request.auth != null
        && request.auth.uid == resource.data.userId;
    }

    match /follows/{followId} {
      allow read: if request.auth != null;
      allow create: if request.auth.uid == request.resource.data.followerId;
      allow delete: if request.auth.uid == resource.data.followerId;
    }

    match /teams/{teamId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.createdBy;

      // Owner may update any field. Non-owner members may only adjust memberCount
      // (e.g. when joining/leaving) or updatedAt. All other fields must remain unchanged.
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.createdBy ||
        (
          exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['memberCount', 'updatedAt'])
        )
      );

      allow delete: if request.auth != null && request.auth.uid == resource.data.createdBy;

      match /members/{memberId} {
        allow read: if request.auth != null;
        allow create: if request.auth.uid == memberId;
        allow delete: if request.auth.uid == memberId
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy;
      }

      match /messages/{messageId} {
        allow read: if exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
        allow create: if exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid))
          && request.auth.uid == request.resource.data.senderId;
        // Sender can retract their own message; team owner can moderate / cleanup on team deletion.
        allow delete: if request.auth != null && (
          request.auth.uid == resource.data.senderId
          || request.auth.uid == get(/databases/$(database)/documents/teams/$(teamId)).data.createdBy
        );
      }
    }

    // CollectionGroup query support — needed for getMyTeams() to find all member docs
    // for a user across all teams. Path-specific rules above don't apply to collectionGroup queries.
    match /{path=**}/members/{memberId} {
      allow read: if request.auth != null && request.auth.uid == memberId;
    }

    match /trainerRelations/{relationId} {
      allow read: if request.auth.uid == resource.data.trainerId
        || request.auth.uid == resource.data.clientId;
      allow create: if request.auth.uid == request.resource.data.trainerId;
      allow update: if request.auth.uid == resource.data.clientId;
    }
  }
}
